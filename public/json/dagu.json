  "features": [
    {
      "title": "Workflow Orchestration",
      "description": "Executes and manages workflows defined as directed acyclic graphs",
      "core_feature": true
    },
    {
      "title": "DAG-Based Scheduling",
      "description": "Runs tasks based on dependency relationships",
      "core_feature": true
    },
    {
      "title": "Web Dashboard",
      "description": "Visualizes workflows task status and execution history",
      "core_feature": true
    },
    {
      "title": "Cron Scheduling",
      "description": "Triggers workflows using time-based schedules"
    },
    {
      "title": "Parameterized Runs",
      "description": "Executes workflows with runtime parameters"
    },
    {
      "title": "Retry and Failure Handling",
      "description": "Manages retries and failure states for tasks"
    },
    {
      "title": "Log Management",
      "description": "Stores and displays task execution logs"
    },
    {
      "title": "CLI Support",
      "description": "Controls workflows from the command line"
    },
    {
      "title": "Self-Hosted Execution",
      "description": "Runs on user-managed infrastructure"
    }
